generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleUsuario {
  ADMIN
  INSTITUICAO
}

enum TipoInstituicao {
  IGREJA
  ASSOCIACAO
  ONG
  OUTRO
}

enum StatusInstituicao {
  OK
  PENDENTE
}

enum TipoBeneficio {
  CESTA
  GRANEL
  AMBOS
}



model Usuario {
  id            Int         @id @default(autoincrement())
  nome          String
  email         String      @unique
  senhaHash     String
  role          RoleUsuario @default(INSTITUICAO)

  ativo         Boolean     @default(true)
  criadoEm      DateTime    @default(now())
  atualizadoEm  DateTime    @updatedAt

  instituicaoId Int?                @unique
  instituicao   InstituicaoParceira? @relation(fields: [instituicaoId], references: [id])

  doacoes       Doacao[]

  
  @@map("usuarios")
}

model InstituicaoParceira {
  id               Int               @id @default(autoincrement())
  nome             String
  email            String            @unique
  tipo             TipoInstituicao   @default(OUTRO)
  responsavel      String
  telefone         String
  endereco         String
  cidade           String
  statusOk         StatusInstituicao @default(PENDENTE)
  ativa            Boolean           @default(true)

  criadoEm         DateTime          @default(now())
  atualizadoEm     DateTime          @updatedAt
  deletedAt        DateTime?

  usuario          Usuario?
  beneficiarios    Beneficiario[]
  doacoes          Doacao[]

  @@map("instituicoes_parceiras")
}

model Beneficiario {
  id                     Int            @id @default(autoincrement())
  nomeCompleto           String
  cpf                    String         @unique
  dataNascimento         DateTime

  // Endereço
  logradouro             String
  numero                 String
  complemento            String?
  cep                    String?
  regiao                 String
  cidade                 String
  uf                     String

  // Contato
  telefonePrincipal      String
  telefoneSecundario     String?
  email                  String?

  instituicaoId          Int
  instituicao            InstituicaoParceira @relation(fields: [instituicaoId], references: [id])

  tipoBeneficio          TipoBeneficio  @default(CESTA)
  situacaoSocioeconomica String?

  dataCadastro           DateTime       @default(now())

  observacoes            String?
  ativo                  Boolean        @default(true)

  criadoEm               DateTime       @default(now())
  atualizadoEm           DateTime       @updatedAt
  deletedAt              DateTime?

  doacoes                Doacao[]

  @@index([instituicaoId])
  @@map("beneficiarios")
}

model Doacao {
  id              Int      @id @default(autoincrement())

  codigo          String   @unique

  beneficiarioId  Int
  beneficiario    Beneficiario @relation(fields: [beneficiarioId], references: [id])

  instituicaoId   Int
  instituicao     InstituicaoParceira @relation(fields: [instituicaoId], references: [id])

  usuarioId       Int
  usuario         Usuario              @relation(fields: [usuarioId], references: [id])

  tipo            TipoBeneficio

  quantidade      Int

  observacoes     String?

  comprovante     Boolean @default(false)

  dataDoacao      DateTime @default(now())

  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt
  deletedAt       DateTime?

  @@index([beneficiarioId])
  @@index([instituicaoId])
  @@index([usuarioId])
  @@index([dataDoacao])
  @@index([instituicaoId, dataDoacao])

  @@map("doacoes")
}